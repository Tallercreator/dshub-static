{
  "family": {
    "base": {
      "$type": "string",
      "$value": "Inter",
      "$extensions": {
        "com.figma.scopes": [
          "FONT_FAMILY"
        ]
      }
    },
    "display": {
      "$type": "string",
      "$value": "Inter",
      "$extensions": {
        "com.figma.scopes": [
          "FONT_FAMILY"
        ]
      }
    }
  },
  "weight": {
    "regular": {
      "$type": "number",
      "$value": 400,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_WEIGHT"
        ]
      }
    },
    "medium": {
      "$type": "number",
      "$value": 500,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_WEIGHT"
        ]
      }
    },
    "semibold": {
      "$type": "number",
      "$value": 600,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_WEIGHT"
        ]
      }
    },
    "bold": {
      "$type": "number",
      "$value": 700,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_WEIGHT"
        ]
      }
    }
  },
  "size": {
    "xs": {
      "$type": "number",
      "$value": 12,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      }
    },
    "sm": {
      "$type": "number",
      "$value": 14,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      }
    },
    "md": {
      "$type": "number",
      "$value": 16,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      }
    },
    "lg": {
      "$type": "number",
      "$value": 20,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      }
    },
    "xl": {
      "$type": "number",
      "$value": 24,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      }
    },
    "2xl": {
      "$type": "number",
      "$value": 32,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      }
    },
    "3xl": {
      "$type": "number",
      "$value": 40,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      }
    },
    "4xl": {
      "$type": "number",
      "$value": 48,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      }
    },
    "5xl": {
      "$type": "number",
      "$value": 64,
      "$extensions": {
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      }
    }
  },
  "line": {
    "tight": {
      "$type": "number",
      "$value": 105,
      "$extensions": {
        "com.figma.scopes": [
          "LINE_HEIGHT"
        ]
      }
    },
    "snug": {
      "$type": "number",
      "$value": 120,
      "$extensions": {
        "com.figma.scopes": [
          "LINE_HEIGHT"
        ]
      }
    },
    "normal": {
      "$type": "number",
      "$value": 140,
      "$extensions": {
        "com.figma.scopes": [
          "LINE_HEIGHT"
        ]
      }
    },
    "relaxed": {
      "$type": "number",
      "$value": 150,
      "$extensions": {
        "com.figma.scopes": [
          "LINE_HEIGHT"
        ]
      }
    }
  },
  "tracking": {
    "tight": {
      "$type": "number",
      "$value": -2,
      "$extensions": {
        "com.figma.scopes": [
          "LETTER_SPACING"
        ]
      }
    },
    "normal": {
      "$type": "number",
      "$value": 0,
      "$extensions": {
        "com.figma.scopes": [
          "LETTER_SPACING"
        ]
      }
    }
  },
  "$extensions": {
    "com.figma.modeName": "Default"
  }
}