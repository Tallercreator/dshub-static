# Форма «Предложить кейс» → Telegram (Netlify Function submit-case).
# Скопируй в .env для локального теста через `netlify dev` (.env в .gitignore).
# На проде задай эти переменные в Netlify UI: Site settings → Environment variables.

# Токен бота от @BotFather (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# id чата/канала, куда слать заявки.
# Узнать свой id: напиши боту @userinfobot, либо после старта своего бота открой
# https://api.telegram.org/bot<ТОКЕН>/getUpdates и возьми chat.id из ответа.
TELEGRAM_CHAT_ID=123456789
