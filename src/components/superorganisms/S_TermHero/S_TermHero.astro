---
// S_TermHero — суперорганизм. Шапка страницы термина (Figma T_Term 36:15116):
// кнопка «назад» (стрелка) + ghost-имя + H1 + ряд фактов (Определение / Для чего
// нужен / Где используется). Пустые факты скрываются.
import Q_Icon from '../../quarks/Q_Icon/Q_Icon.astro';
import styles from './S_TermHero.module.css';

interface Props {
  term: string;
  definition?: string;
  purpose?: string;
  usage?: string;
  backHref?: string;
}
const { term, definition, purpose, usage, backHref = '/glossary' } = Astro.props;

const facts = [
  { icon: 'check', label: 'Определение', value: definition },
  { icon: 'lightbulb', label: 'Для чего нужен', value: purpose },
  { icon: 'loupe', label: 'Где используется', value: usage },
].filter((f) => f.value);
---
<section class={styles.hero}>
  <span class={styles.ghost} aria-hidden="true">{term}</span>
  <div class={styles.veil}></div>

  <div class={styles.inner}>
    <div class={styles.topRow}>
      <a class={styles.back} href={backHref} aria-label="Назад в глоссарий">
        <span class={styles.backIcon}><Q_Icon name="chevron-right" size={16} /></span>
      </a>
      <h1 class={styles.name}>{term}</h1>
    </div>

    <div class={styles.facts}>
      {facts.map((f) => (
        <div class={styles.fact}>
          <Q_Icon name={f.icon} size={20} class={styles.factIcon} />
          <span class={styles.factLabel}>{f.label}</span>
          <p class={styles.factValue}>{f.value}</p>
        </div>
      ))}
    </div>

    <button
      type="button"
      class={styles.share}
      data-share-term
      data-term={term}
      data-definition={definition ?? ''}
      data-purpose={purpose ?? ''}
      data-usage={usage ?? ''}
    >
      <span class={styles.shareLabel} data-share-label>Поделиться термином</span>
      <Q_Icon name="link" size={16} />
    </button>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-share-term]').forEach((btn) => {
    const label = btn.querySelector<HTMLElement>('[data-share-label]');
    btn.addEventListener('click', async () => {
      const term = btn.dataset.term || '';
      const definition = btn.dataset.definition || '';
      const purpose = btn.dataset.purpose || '';
      const usage = btn.dataset.usage || '';
      const parts = [term];
      if (definition) parts.push('', 'Определение:', definition);
      if (purpose) parts.push('', 'Для чего нужен:', purpose);
      if (usage) parts.push('', 'Где используется:', usage);
      // декодируем кириллицу в URL, чтобы ссылка читалась в чатах
      let url = window.location.href;
      try { url = decodeURI(url); } catch {}
      parts.push('', url);
      const text = parts.join('\n');
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch {}
        ta.remove();
      }
      if (label) {
        const prev = label.textContent;
        label.textContent = 'Скопировано';
        btn.classList.add('is-copied');
        setTimeout(() => {
          label.textContent = prev;
          btn.classList.remove('is-copied');
        }, 2000);
      }
    });
  });
</script>
