---
// W_CardGrid — обёртка. Адаптивная сетка карточек (Figma W_CardGrid 29:3840).
// cols=3 (Главная) / cols=2 (страница Кейсов), gap 24. Контент — слотом.
import styles from './W_CardGrid.module.css';

interface Props {
  cols?: 2 | 3;
  class?: string;
}
const { cols = 3, class: extra } = Astro.props;
---

<div class:list={[styles.grid, styles[`cols${cols}`], extra]}><slot /></div>
