---
// O_Quote — пулл-цитата (Figma 34:2982). Серая плашка (surface/page) с лаймовой
// верхней границей. Без своего тоггла — на странице кейса все цитаты собраны в
// один блок «Избранные цитаты» (O_FeaturedQuotes) с общим скрытием/раскрытием.
interface Props {
  text: string;
  author?: string;
  title?: string;
}
const { text, author, title } = Astro.props;
---
<figure class="block-quote">
  {title && <span class="quote-label">{title}</span>}
  <blockquote class="quote-text" set:html={text} />
  {author && <figcaption class="quote-author">{author}</figcaption>}
</figure>

<style>
  .block-quote {
    margin: 0;
    padding: var(--space-3xl);
    background: var(--surface-page);
    border-top: 2px solid var(--lime-20);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .quote-label {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-medium);
    color: var(--text-tertiary);
  }
  .quote-text {
    margin: 0;
    font-family: var(--font-family-base);
    font-weight: var(--font-weight-medium);
    font-style: italic;
    font-size: var(--font-size-md);
    line-height: 1.3;
    color: var(--text-primary);
  }
  .quote-author {
    font-size: 14px;
    color: var(--text-tertiary);
  }
</style>
