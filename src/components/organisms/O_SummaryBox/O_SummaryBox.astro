---
// O_SummaryBox — блок «Выводы» (чек-лист). Блок type:"summary".
// TODO (вторая волна): пункт → M_CheckItem ← A_Icon(✓) + A_Text; ✓ заменить на Q_Icon.
import A_Text from '../../atoms/A_Text/A_Text.astro';

interface Props {
  items: string[];
}
const { items = [] } = Astro.props;
---
<div class="block-summary">
  <ul class="summary-list">
    {items.map((item) => (
      <li class="summary-item">
        <span class="summary-check" aria-hidden="true">✓</span>
        <A_Text variant="body" color="primary" set:html={item} />
      </li>
    ))}
  </ul>
</div>

<style>
  .block-summary {
    margin-block: var(--layout-xs);
    padding: var(--space-3xl);
    background: var(--surface-card);
    border: var(--border-hairline) solid var(--stroke-subtle);
    border-radius: var(--radius-lg);
  }
  .summary-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
  .summary-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
  }
  .summary-check {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--size-icon-md);
    height: var(--size-icon-md);
    color: var(--icons-accent);
    font-weight: var(--font-weight-bold);
  }
</style>
