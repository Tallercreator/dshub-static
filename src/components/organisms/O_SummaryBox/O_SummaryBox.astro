---
// O_SummaryBox — блок «Главное / Выводы» (Figma 34:2937). Серая плашка
// (surface/page, скругление 24px, паддинг 24px), внутри — нумерованный список
// ключевых тезисов (как O_NumberedList). items — массив строк ИЛИ {title, text}.
interface Item {
  title: string;
  text?: string;
}
interface Props {
  items: (string | Item)[];
}
const { items = [] } = Astro.props;
const norm: Item[] = items.map((it) => (typeof it === 'string' ? { title: it } : it));
---
<div class="block-summary">
  <ol class="summary-list">
    {norm.map((item) => (
      <li class="summary-item">
        <span class="summary-title" set:html={item.title} />
        {item.text && <p class="summary-desc" set:html={item.text} />}
      </li>
    ))}
  </ol>
</div>

<style>
  .block-summary {
    margin-block: var(--space-3xl); /* 24 */
    padding: var(--space-3xl);
    background: var(--surface-page);
    border-radius: var(--radius-2xl);
  }
  .summary-list {
    margin: 0;
    padding-left: 30px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
    list-style: decimal;
  }
  .summary-item {
    font-family: var(--font-family-base);
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-lg);
    line-height: 1.2;
    color: var(--text-primary);
  }
  .summary-item::marker {
    font-weight: var(--font-weight-medium);
  }
  .summary-title {
    font: inherit;
  }
  .summary-desc {
    margin: var(--space-md) 0 0;
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-md);
    line-height: 1.4;
    color: var(--text-secondary);
  }
</style>
