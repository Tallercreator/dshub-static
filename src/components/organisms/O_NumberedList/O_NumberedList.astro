---
// O_NumberedList — нумерованный список. Блок type:"numbered-list".
// TODO (вторая волна): декомпозировать пункт в M_NumberedItem ← A_Badge + A_Text.
import A_Text from '../../atoms/A_Text/A_Text.astro';

interface Props {
  items: string[];
}
const { items = [] } = Astro.props;
---
<ol class="block-numbered">
  {items.map((item, i) => (
    <li class="numbered-item">
      <span class="numbered-badge"><A_Text variant="caption" color="on-accent">{i + 1}</A_Text></span>
      <A_Text variant="body" color="secondary" set:html={item} />
    </li>
  ))}
</ol>

<style>
  .block-numbered {
    list-style: none;
    margin-block: var(--layout-xs);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
  .numbered-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
  }
  .numbered-badge {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--size-icon-lg);
    height: var(--size-icon-lg);
    border-radius: var(--radius-pill);
    background: var(--surface-accent);
  }
</style>
