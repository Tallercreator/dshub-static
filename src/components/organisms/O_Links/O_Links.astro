---
// O_Links — блок ссылок. Блок type:"links" { links:[{text,url,external}] }
// (схема одногруппника). Внешние ссылки открываются в новой вкладке.
import A_Text from '../../atoms/A_Text/A_Text.astro';
import Q_Icon from '../../quarks/Q_Icon/Q_Icon.astro';

interface LinkItem {
  text: string;
  url: string;
  external?: boolean;
}
interface Props {
  links: LinkItem[];
}
const { links = [] } = Astro.props;
---
<ul class="block-links">
  {links.map((l) => (
    <li>
      <a
        href={l.url}
        class="block-link"
        target={l.external ? '_blank' : undefined}
        rel={l.external ? 'noopener noreferrer' : undefined}
      >
        <A_Text variant="body" color="accent">{l.text}</A_Text>
        {l.external && <Q_Icon name="upright-arrow" size={16} class="ext" />}
      </a>
    </li>
  ))}
</ul>

<style>
  .block-links {
    list-style: none;
    margin-block: var(--layout-xs);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .block-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--text-accent);
  }
  .block-link:hover { text-decoration: underline; }
  .ext { color: var(--icons-accent); }
</style>
