---
// O_Paragraph — абзац статьи (Figma 34:3075). Inter Display Regular 16px,
// text/secondary, line-height 1.4. text может содержать инлайн-разметку
// (наш контент → set:html безопасен).
interface Props {
  text: string;
}
const { text } = Astro.props;
---
<p class="block-paragraph" set:html={text} />

<style>
  .block-paragraph {
    margin-block: var(--space-3xl); /* 24 — между текстовыми блоками */
    font-family: var(--font-family-base);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-md);
    line-height: 1.4;
    color: var(--text-secondary);
  }
</style>
