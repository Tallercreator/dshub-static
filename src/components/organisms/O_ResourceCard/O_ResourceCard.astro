---
// O_ResourceCard — карточка ресурса (Figma 30:4664/4665).
// size=medium: M_SourceLink (Label + источник) сверху → вшитая обложка-контейнер
//   (радиус 12, object-cover) → заголовок снизу.
// size=large: Label + заголовок слева, обложка справа (span 2).
// surface: card (белая, по умолчанию) | page (серая, новая вариация). Тег и
//   плейсхолдер обложки адаптируются под фон. Вся карточка — внешняя ссылка.
import A_Tag from '../../atoms/A_Tag/A_Tag.astro';
import M_SourceLink from '../../molecules/M_SourceLink/M_SourceLink.astro';
import styles from './O_ResourceCard.module.css';

interface Props {
  size?: 'large' | 'medium';
  label?: string;
  title: string;
  source?: string;
  url: string;
  coverImage?: string;
  surface?: 'card' | 'page'; // card=белая (default), page=серая (новая вариация)
  class?: string;
}
const {
  size = 'medium',
  label,
  title,
  source,
  url,
  coverImage,
  surface = 'card',
  class: extra,
  ...rest
} = Astro.props;
const isLarge = size === 'large';
// серая карточка → белый тег; белая карточка → серый тег
const tagVariant = surface === 'page' ? 'card' : 'white';
---
<article class:list={[styles.card, styles[size], styles[`s-${surface}`], extra]} {...rest}>
  {isLarge ? (
    <>
      <div class={styles.content}>
        {label && <A_Tag variant={tagVariant} size="md" class={styles.badge}>{label}</A_Tag>}
        <h3 class={styles.title}>
          <a class={styles.titleLink} href={url} target="_blank" rel="noopener noreferrer">{title}</a>
        </h3>
      </div>
      <div class={styles.cover}>
        {coverImage && <img class={styles.img} src={coverImage} alt="" loading="lazy" decoding="async" />}
      </div>
    </>
  ) : (
    <div class={styles.content}>
      <M_SourceLink label={label} source={source} url={url} tagVariant={tagVariant} />
      {/* гибкий элемент-заполнитель прижимает заголовок к низу: с картинкой —
          обложка, без картинки — невидимый пустой блок (область не видна) */}
      <div class:list={[styles.cover, coverImage && styles.coverFilled]}>
        {coverImage && <img class={styles.img} src={coverImage} alt="" loading="lazy" decoding="async" />}
      </div>
      <h3 class={styles.title}>
        <a class={styles.titleLink} href={url} target="_blank" rel="noopener noreferrer">{title}</a>
      </h3>
    </div>
  )}
</article>
