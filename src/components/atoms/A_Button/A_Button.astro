---
// A_Button.astro — атом. Сквозной нейминг = Figma-компонент A_Button (node 18:3660).
// Оси Figma: contentType × size × state. Состояния (hover/pressed/disabled) — это CSS,
// не пропсы (правило UDF). Loading — пропс (показывает спиннер вместо контента).
// Презентационный → .astro (zero-JS). Иконку передавать слотом name="icon" (Q_Icon).
import styles from './A_Button.module.css';

interface Props {
  // = Figma Content_type: Icon · Text · Text+RightIcon · Primary · Neutral
  contentType?: 'icon' | 'text' | 'text-righticon' | 'primary' | 'neutral';
  // = Figma Size: Small_32 · Medium_40 · Large_48 (Neutral всегда XLarge_110)
  size?: 'sm' | 'md' | 'lg';
  loading?: boolean;
  disabled?: boolean;
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
}

const {
  contentType = 'text',
  size = 'lg',
  loading = false,
  disabled = false,
  href,
  type = 'button',
  class: extra,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
const isInactive = disabled || loading;
const hasLabel = contentType === 'text' || contentType === 'text-righticon' || contentType === 'neutral';
const hasIcon = contentType !== 'text';

const cls = [
  styles.button,
  styles[`ct-${contentType}`],
  contentType === 'neutral' ? null : styles[`size-${size}`],
  loading && styles.loading,
  extra,
]
  .filter(Boolean)
  .join(' ');
---

<Tag
  class={cls}
  href={href}
  type={href ? undefined : type}
  disabled={href ? undefined : isInactive}
  aria-busy={loading ? 'true' : undefined}
  aria-disabled={href && isInactive ? 'true' : undefined}
  {...rest}
>
  <span class={styles.spinner} aria-hidden="true"></span>
  {hasLabel && <span class={styles.label}><slot /></span>}
  {hasIcon && <span class={styles.icon}><slot name="icon" /></span>}
</Tag>
