---
// index.astro — Главная (T_Home). Собрана из суперорганизмов:
// S_Hero → S_CasesSection → S_TermsSection → S_ResourcesSection → S_Form.
// Шапка (O_Header) и футер (O_Footer) — глобальные, из BaseLayout.
import BaseLayout from '../layouts/BaseLayout.astro';
import S_Hero from '../components/superorganisms/S_Hero/S_Hero.astro';
import S_CasesSection from '../components/superorganisms/S_CasesSection/S_CasesSection.astro';
import S_TermsSection from '../components/superorganisms/S_TermsSection/S_TermsSection.astro';
import S_ResourcesSection from '../components/superorganisms/S_ResourcesSection/S_ResourcesSection.astro';
import S_Form from '../components/superorganisms/S_Form/S_Form.astro';
import W_PageContainer from '../components/wrappers/W_PageContainer/W_PageContainer.astro';

const cases = Object.values(import.meta.glob('../content/cases/*.json', { eager: true })).map(
  (m) => m.default,
);
const terms = Object.values(import.meta.glob('../content/terms/*.json', { eager: true })).map(
  (m) => m.default,
);
const resources = Object.values(import.meta.glob('../content/resources/*.json', { eager: true })).map(
  (m) => m.default,
);
const termsWithDef = terms.filter((t) => t.definition);

// Превью глоссария (4 карточки). Вариант (lime/pink/image) пока задаём явно для
// демонстрации — в данных нет поля сложности; маппинг term→variant решим позже.
const glossaryPreviewVariants = ['pink', 'image', 'lime', 'pink'];
const glossaryItems = termsWithDef.slice(0, 4).map((t, i) => ({
  term: t.term,
  definition: t.definition,
  variant: glossaryPreviewVariants[i],
}));

// Превью ресурсов (5 карточек, первая — широкая). Обложки/иллюстрации позже.
const resourceItems = resources.slice(0, 5).map((r) => ({
  type: r.type,
  title: r.title,
  source: r.source,
  url: r.url,
}));
---

<BaseLayout title="DSHub — онлайн-медиа о дизайн-системах">
  <S_Hero />

  <W_PageContainer type="linear">
    <S_CasesSection cases={cases.filter((c) => c.published)} limit={5} offsetFirst />
  </W_PageContainer>

  <W_PageContainer type="solid">
    <S_TermsSection items={glossaryItems} />
  </W_PageContainer>

  <W_PageContainer type="solid-gray">
    <S_ResourcesSection items={resourceItems} />
  </W_PageContainer>

  <S_Form />
</BaseLayout>
