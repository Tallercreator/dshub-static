---
// index.astro — временный styleguide/skeleton: доказывает, что токены и атомы
// живут и связаны. Настоящая Главная (T_Home) собирается в следующей волне из
// O_Header + S_Hero + … (см. 03-build-checklist.md).
import BaseLayout from '../layouts/BaseLayout.astro';
import A_Text from '../components/atoms/A_Text/A_Text.astro';
import A_Button from '../components/atoms/A_Button/A_Button.astro';
import Q_Icon from '../components/quarks/Q_Icon/Q_Icon.astro';
import Q_Logo from '../components/quarks/Q_Logo/Q_Logo.astro';
import A_Checkbox from '../components/atoms/A_Checkbox/A_Checkbox.astro';
import A_Tag from '../components/atoms/A_Tag/A_Tag.astro';
import A_CategoryTag from '../components/atoms/A_CategoryTag/A_CategoryTag.astro';
import A_SegmentItem from '../components/atoms/A_SegmentItem/A_SegmentItem.astro';
import A_Link from '../components/atoms/A_Link/A_Link.astro';
import { ICONS } from '../components/quarks/Q_Icon/icons';

const iconNames = Object.keys(ICONS);

const cases = Object.values(import.meta.glob('../content/cases/*.json', { eager: true })).map(
  (m) => m.default,
);
const terms = Object.values(import.meta.glob('../content/terms/*.json', { eager: true })).map(
  (m) => m.default,
);
const resources = Object.values(import.meta.glob('../content/resources/*.json', { eager: true })).map(
  (m) => m.default,
);
const termsWithDef = terms.filter((t) => t.definition);
---

<BaseLayout title="DSHub — каркас (styleguide)">
  <main class="wrap">
    <header class="head">
      <A_Text variant="caption" color="accent">DSHub · каркас v0</A_Text>
      <A_Text as="h1" variant="display" color="primary">Дизайн-система в коде</A_Text>
      <A_Text as="p" variant="body" color="secondary">
        Токены → CSS-переменные, атомы по UDF, контент из JSON через ContentRenderer.
      </A_Text>
    </header>

    <section class="section">
      <A_Text as="h2" variant="h2" color="primary">Типографика (A_Text)</A_Text>
      <div class="stack">
        <A_Text variant="display">Display 64</A_Text>
        <A_Text variant="h1">Heading 1 · 48</A_Text>
        <A_Text variant="h2">Heading 2 · 40</A_Text>
        <A_Text variant="title">Title · 20</A_Text>
        <A_Text variant="body" color="secondary">Body · 16 — основной текст абзацев и описаний.</A_Text>
        <A_Text variant="caption" color="tertiary">Caption · 14 — подписи и мета.</A_Text>
      </div>
    </section>

    <section class="section">
      <A_Text as="h2" variant="h2" color="primary">Кнопки (A_Button) — 1:1 с Figma</A_Text>

      <A_Text variant="caption" color="tertiary">contentType=text · size sm / md / lg</A_Text>
      <div class="row">
        <A_Button contentType="text" size="sm">Small 32</A_Button>
        <A_Button contentType="text" size="md">Medium 40</A_Button>
        <A_Button contentType="text" size="lg">Large 48</A_Button>
      </div>

      <A_Text variant="caption" color="tertiary">состояния (hover/active навести/нажать) + disabled + loading</A_Text>
      <div class="row">
        <A_Button contentType="text" size="lg">Normal</A_Button>
        <A_Button contentType="text" size="lg" disabled>Disabled</A_Button>
        <A_Button contentType="text" size="lg" loading>Loading</A_Button>
      </div>

      <A_Text variant="caption" color="tertiary">contentType=text-lefticon / icon / primary (с Q_Icon)</A_Text>
      <div class="row">
        <A_Button contentType="text-lefticon" size="lg">
          Все кейсы
          <Q_Icon slot="icon" name="arrow-right" size={24} />
        </A_Button>
        <A_Button contentType="icon" size="lg" aria-label="В избранное">
          <Q_Icon slot="icon" name="heart" size={24} title="В избранное" />
        </A_Button>
        <A_Button contentType="primary" size="md" aria-label="Фильтр">
          <Q_Icon slot="icon" name="filter" size={16} title="Фильтр" />
        </A_Button>
      </div>

      <A_Text variant="caption" color="tertiary">contentType=neutral — большой XL-CTA-пилл</A_Text>
      <div class="row">
        <A_Button contentType="neutral">
          Смотреть кейсы
          <Q_Icon slot="icon" name="arrow-right" size={24} />
        </A_Button>
      </div>
    </section>

    <section class="section">
      <A_Text as="h2" variant="h2" color="primary">Атомы — из Figma</A_Text>

      <A_Text variant="caption" color="tertiary">A_Checkbox (наведи/нажми/отметь)</A_Text>
      <div class="row">
        <A_Checkbox />
        <A_Checkbox checked />
        <A_Checkbox disabled />
        <A_Checkbox checked disabled />
      </div>

      <A_Text variant="caption" color="tertiary">A_Tag — black / white · sm / md · с иконкой</A_Text>
      <div class="row">
        <A_Tag variant="black" size="md">Бигтех</A_Tag>
        <A_Tag variant="white" size="md">Fintech</A_Tag>
        <A_Tag variant="black" size="sm">Статья</A_Tag>
        <A_Tag variant="white" size="sm">
          <Q_Icon slot="icon" name="cross-small" size={16} />
          Убрать
        </A_Tag>
        <A_Tag variant="black" size="md" disabled>Disabled</A_Tag>
      </div>

      <A_Text variant="caption" color="tertiary">A_CategoryTag («↗ Токены»)</A_Text>
      <div class="row">
        <A_CategoryTag>Токены</A_CategoryTag>
        <A_CategoryTag>Документация</A_CategoryTag>
        <A_CategoryTag>Компоненты</A_CategoryTag>
      </div>

      <A_Text variant="caption" color="tertiary">A_SegmentItem — sm / md / lg · selected</A_Text>
      <div class="row" style="background: var(--surface-page); padding: var(--space-md); border-radius: var(--radius-md);">
        <A_SegmentItem size="md" selected>Кейсы</A_SegmentItem>
        <A_SegmentItem size="md">Словарь</A_SegmentItem>
        <A_SegmentItem size="md">Ресурсы</A_SegmentItem>
        <A_SegmentItem size="sm">Small</A_SegmentItem>
        <A_SegmentItem size="lg">Large</A_SegmentItem>
      </div>

      <A_Text variant="caption" color="tertiary">A_Link (hover → лайм)</A_Text>
      <div class="row">
        <A_Link href="#">Перейти к разделу</A_Link>
        <A_Link href="#" external>Внешняя ссылка</A_Link>
      </div>
    </section>

    <section class="section">
      <A_Text as="h2" variant="h2" color="primary">Логотип (Q_Logo) — из Figma</A_Text>
      <div class="row" style="align-items: center; gap: var(--layout-sm);">
        <Q_Logo type="lockup" />
        <Q_Logo type="icon" />
      </div>
    </section>

    <section class="section">
      <A_Text as="h2" variant="h2" color="primary">Иконки (Q_Icon) — из Figma</A_Text>
      <A_Text variant="caption" color="tertiary">{iconNames.length} иконок · currentColor · ориентация из Figma</A_Text>
      <div class="icon-gallery">
        {iconNames.map((n) => (
          <div class="icon-cell">
            <Q_Icon name={n} size={24} />
            <A_Text variant="caption" color="tertiary">{n}</A_Text>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <A_Text as="h2" variant="h2" color="primary">Контент из JSON</A_Text>
      <div class="stack">
        <A_Text variant="title" color="primary">Кейсы ({cases.length})</A_Text>
        <ul class="links">
          {cases.map((c) => (
            <li>
              <a href={`/cases/${c.slug}`}>
                <A_Text variant="body" color="accent">→ {c.title}</A_Text>
              </a>
            </li>
          ))}
        </ul>
        <A_Text variant="title" color="primary">
          Термины ({terms.length}) · с определением: {termsWithDef.length}
        </A_Text>
        {termsWithDef.slice(0, 4).map((t) => (
          <div class="term">
            <A_Text variant="title" color="primary">{t.term}</A_Text>
            <A_Text variant="caption" color="tertiary">{t.category} · {t.visualType}</A_Text>
            <A_Text variant="body" color="secondary">{t.definition}</A_Text>
          </div>
        ))}

        <A_Text variant="title" color="primary">Ресурсы ({resources.length})</A_Text>
        <ul class="links">
          {resources.slice(0, 5).map((r) => (
            <li>
              <a href={r.url} target="_blank" rel="noopener noreferrer">
                <A_Text variant="body" color="accent">→ [{r.source}] {r.title}</A_Text>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .wrap {
    max-width: 880px;
    margin-inline: auto;
    padding: var(--layout-2xl) var(--layout-xs);
    display: flex;
    flex-direction: column;
    gap: var(--layout-xl);
  }
  .head { display: flex; flex-direction: column; gap: var(--space-lg); }
  .section { display: flex; flex-direction: column; gap: var(--space-3xl); }
  .stack { display: flex; flex-direction: column; gap: var(--space-xl); align-items: flex-start; }
  .row { display: flex; gap: var(--space-xl); align-items: center; flex-wrap: wrap; }
  .links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-md); }
  .term {
    display: flex; flex-direction: column; gap: var(--space-md);
    padding: var(--space-3xl);
    background: var(--surface-card);
    border: var(--border-hairline) solid var(--stroke-subtle);
    border-radius: var(--radius-lg);
  }
  .icon-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: var(--space-md);
  }
  .icon-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-xl) var(--space-md);
    background: var(--surface-card);
    border: var(--border-hairline) solid var(--stroke-subtle);
    border-radius: var(--radius-md);
    color: var(--icons-primary);
    text-align: center;
  }
</style>
