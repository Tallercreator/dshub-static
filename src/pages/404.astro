---
import BaseLayout from '../layouts/BaseLayout.astro';
import A_Text from '../components/atoms/A_Text/A_Text.astro';
import A_Button from '../components/atoms/A_Button/A_Button.astro';
---
<BaseLayout title="404 — DSHub">
  <main class="nf">
    <A_Text as="h1" variant="display" color="primary">404</A_Text>
    <A_Text variant="body" color="secondary">Страница не найдена.</A_Text>
    <A_Button href="/" contentType="text" size="lg">На главную</A_Button>
  </main>
</BaseLayout>
<style>
  .nf {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xl);
    text-align: center;
  }
</style>
